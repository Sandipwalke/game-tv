{
  "name": "game-tv-town-sim",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json && mkdir -p server-dist/sql && cp server/sql/init.sql server-dist/sql/init.sql",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "server:dev": "tsx watch server/index.ts",
    "start": "node server-dist/index.js"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.4",
    "@react-three/fiber": "^9.4.0",
    "@types/three": "^0.180.0",
